extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Oficina AutoRepair
      p.w3-opacity Lista de todas as reparações registadas

    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th ID
          th Data
          th Cliente
          th Matrícula
          th Marca
          th Nº Intervenções
        each r in list
          tr.w3-hover-light-grey
            td
              a(href=`/${r._id}`)= r._id
            td= r.data
            td= r.nome
            td= r.viatura.matricula
            td
              a(href=`/${r.viatura.marca}`)= r.viatura.marca
            td= r.nr_intervencoes
