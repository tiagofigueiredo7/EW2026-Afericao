extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1= marca
      p.w3-opacity Reparações registadas para esta marca

    .w3-container.w3-margin-top
      h3 Modelos intervencionados
      ul.w3-ul.w3-border
        each m in modelos
          li= m

    .w3-container.w3-margin-top
      h3 Registos de reparação
      table.w3-table-all.w3-margin-top
        tr
          th ID
          th Data
          th Cliente
          th Matrícula
          th Marca
          th Nº Intervenções
        each r in list
          tr.w3-hover-light-grey
            td
              a(href=`/${r._id}`)= r._id
            td= r.data
            td= r.nome
            td= r.viatura.matricula
            td= r.viatura.marca
            td= r.nr_intervencoes

    .w3-container.w3-margin-top.w3-margin-bottom
      a.w3-btn.w3-grey.w3-border.w3-border-black(href="/") ← Voltar à lista
